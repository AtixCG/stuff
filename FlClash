rule-providers:
  telegram-ips:
    type: http
    behavior: ipcidr
    format: mrs
    interval: 86400
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geoip/telegram.mrs
    path: ./rule-sets/telegram-ips.mrs
  telegram-domains:
    type: http
    behavior: domain
    format: mrs
    interval: 86400
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/telegram.mrs
    path: ./rule-sets/telegram-domains.mrs
  geosite-private:
    type: http
    behavior: domain
    format: mrs
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/private.mrs
    path: ./rule-sets/geosite-private.mrs
    interval: 86400
  geoip-private:
    type: http
    behavior: ipcidr
    format: mrs
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geoip/private.mrs
    path: ./rule-sets/geoip-private.mrs
    interval: 86400

rules:
  # Системные и локальные подключения (оставляем без VPN для стабильности)
  - DST-PORT,53,DNS-OUT
  - RULE-SET,geoip-private,DIRECT,no-resolve
  - RULE-SET,geosite-private,DIRECT

  # Домены со скриншота -> Мои домены
  - DOMAIN,x.com,Мои домены
  - DOMAIN,4pda.to,Мои домены
  - DOMAIN,ecosia.org,Мои домены
  - DOMAIN,www.etsy.com,Мои домены
  - DOMAIN,app.cookiecad.com,Мои домены
  - DOMAIN,etsy.com,Мои домены
  - DOMAIN,lh3.googleusercontent.com,Мои домены
  - DOMAIN,work.fife.usercontent.google.com,Мои домены
  - DOMAIN,play.google.com,Мои домены
  - DOMAIN,sponsor.ajay.app,Мои домены
  - DOMAIN,rdl.ink,Мои домены
  - DOMAIN,o199199.ingest.sentry.io,Мои домены
  - DOMAIN,up.raindrop.io,Мои домены
  - DOMAIN,app.raindrop.io,Мои домены

  # Правила Telegram -> Мои домены
  - RULE-SET,telegram-ips,Мои домены
  - RULE-SET,telegram-domains,Мои домены
  - PROCESS-NAME-REGEX,(?i).*ayugram.*,Мои домены
  - PROCESS-NAME-REGEX,(?i).*telegram.*,Мои домены

  # Все остальные сайты и трафик -> Без VPN
  - MATCH,🇷🇺 Без VPN
